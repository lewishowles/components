{
	"name": "@lewishowles/components",
	"version": "2.3.1",
	"description": "A library of beautiful components, promoting rapid development, while ensuring that usability and accessibility are at the fore.",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/lewishowles/components.git"
	},
	"bin": {
		"components": "./bin/cli.js"
	},
	"files": [
		"bin",
		"dist",
		"src/cli",
		"src/components/component-metadata.js",
		"src/components/**/*.metadata.js"
	],
	"type": "module",
	"sideEffects": [
		"**/*.css"
	],
	"main": "dist/components.js",
	"module": "dist/components.js",
	"imports": {
		"#test/*": "./test/*"
	},
	"exports": {
		".": {
			"import": "./dist/components.js"
		},
		"./composables": {
			"types": "./dist/composables.d.ts",
			"import": "./dist/composables.js"
		},
		"./utilities": {
			"types": "./dist/utilities.d.ts",
			"import": "./dist/utilities.js"
		},
		"./resolver": {
			"types": "./dist/resolver.d.ts",
			"import": "./dist/resolver.js"
		},
		"./source": "./dist/source.css",
		"./styles": "./dist/styles.css",
		"./styles/animation": "./dist/css/animation.css",
		"./styles/buttons": "./dist/css/buttons.css",
		"./styles/components": "./dist/css/components.css",
		"./styles/form": "./dist/css/form.css",
		"./styles/main": "./dist/css/main.css",
		"./styles/theme": "./dist/css/theme.css"
	},
	"publishConfig": {
		"registry": "https://npm.pkg.github.com/"
	},
	"scripts": {
		"dev": "vp dev",
		"test:unit": "vp test",
		"test:component": "playwright test -c test/playwright-ct.config.js --project=chromium",
		"publint": "publint",
		"build": "vp build",
		"build:docs": "vp build --config support/vite.config.docs.js",
		"deploy": "bun run build:docs; gh-pages -d dist-docs --cname components.howles.dev --dotfiles",
		"preview": "vp preview",
		"check": "vp check --fix",
		"check:declarations": "node scripts/check-declarations.js",
		"check:exports": "node scripts/smoke-test-exports.js",
		"attw": "attw --pack --profile esm-only --exclude-entrypoints '.' './source' './styles' './styles/animation' './styles/buttons' './styles/components' './styles/form' './styles/main' './styles/theme'",
		"prepare": "vp config"
	},
	"dependencies": {
		"@clack/prompts": "^1.5.1",
		"@lewishowles/helpers": "^1.4.1",
		"@vueuse/core": "^14.3.0",
		"cli-highlight": "^2.1.11",
		"clsx": "^2.1.1",
		"nanoid": "^5.1.14",
		"tailwind-merge": "^3.6.0",
		"temporal-polyfill": "^1.0.1"
	},
	"devDependencies": {
		"@arethetypeswrong/cli": "^0.18.3",
		"@eslint/js": "^10.0.1",
		"@lewishowles/testing": "^1.1.0",
		"@playwright/experimental-ct-vue": "^1.61.0",
		"@stylistic/eslint-plugin": "^5.10.0",
		"@tailwindcss/container-queries": "^0.1.1",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.20",
		"@tailwindcss/vite": "^4.3.1",
		"@vitejs/plugin-vue": "^6.0.7",
		"@vue/test-utils": "^2.4.11",
		"eslint-plugin-vue": "^10.9.2",
		"gh-pages": "^6.3.0",
		"globals": "^17.6.0",
		"happy-dom": "^20.10.6",
		"publint": "^0.3.21",
		"shiki": "^4.2.0",
		"tailwindcss": "^4.3.1",
		"tailwindcss-hocus": "^1.0.0",
		"typescript": "^6.0.3",
		"unplugin-vue-components": "^32.1.0",
		"vite": "npm:@voidzero-dev/vite-plus-core@0.2.1",
		"vite-plugin-vue-devtools": "^8.1.3",
		"vite-plus": "0.2.1",
		"vue-component-meta": "^3.3.5",
		"vue-eslint-parser": "^10.4.1",
		"vue-router": "^5.1.0"
	},
	"peerDependencies": {
		"vue": "^3.4.0"
	},
	"engines": {
		"node": ">=20"
	},
	"packageManager": "bun@1.3.14"
}
