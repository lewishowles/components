{
	"name": "@lewishowles/components",
	"version": "1.10.0",
	"description": "A library of beautiful components, promoting rapid development, while ensuring that usability and accessibility are at the fore.",
	"repository": {
		"type": "git",
		"url": "https://github.com/lewishowles/components.git"
	},
	"files": [
		"dist"
	],
	"type": "module",
	"main": "dist/components.js",
	"module": "dist/components.js",
	"exports": {
		".": {
			"import": "./dist/components.js",
			"require": "./dist/components.js"
		},
		"./composables": {
			"import": "./dist/composables.js",
			"require": "./dist/composables.js"
		}
	},
	"publishConfig": {
		"registry": "https://npm.pkg.github.com/"
	},
	"scripts": {
		"dev": "vp dev",
		"build": "vp build",
		"build:docs": "vp build --config vite.config.docs.js && cp dist-docs/index.html dist-docs/404.html",
		"preview": "vp preview",
		"test:unit": "vp test",
		"test:unit:run": "vp test run",
		"test:component": "cypress run --component",
		"lint": "vp lint . --fix",
		"deploy": "bun run build:docs; gh-pages -d dist-docs --cname components.howles.dev",
		"prepare": "vp config"
	},
	"dependencies": {
		"@lewishowles/helpers": "^0.19.0",
		"@lewishowles/testing": "^0.10.0",
		"@tailwindcss/vite": "^4.3.0",
		"@vueuse/core": "^14.3.0",
		"nanoid": "^5.1.11",
		"vue": "^3.5.35"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@stylistic/eslint-plugin": "^5.10.0",
		"@tailwindcss/container-queries": "^0.1.1",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@vitejs/plugin-vue": "^6.0.7",
		"@vue/test-utils": "^2.4.10",
		"cypress": "^15.16.0",
		"cypress-real-events": "^1.15.0",
		"eslint-plugin-cypress": "^6.4.1",
		"eslint-plugin-vue": "^10.9.1",
		"gh-pages": "^6.3.0",
		"globals": "^17.6.0",
		"happy-dom": "^20.9.0",
		"tailwindcss": "^4.3.0",
		"tailwindcss-hocus": "^1.0.0",
		"temporal-polyfill": "^0.3.2",
		"vite": "8.0.14",
		"vite-plugin-vue-devtools": "^8.1.2",
		"vite-plus": "^0.1.22",
		"vitest": "npm:@voidzero-dev/vite-plus-test@latest",
		"vue-eslint-parser": "^10.4.0",
		"vue-router": "^5.0.7"
	},
	"packageManager": "bun@1.3.14"
}
